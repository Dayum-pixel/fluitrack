# Supabase Postgres (Session or Transaction pooler)
DATABASE_URL=postgresql://postgres.[your-project-ref]:[YOUR_PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
# or if you picked 6543: ...:6543/postgres

# HiveMQ Cloud MQTT
MQTT_BROKER=your-cluster.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=fluitrack-sensor
MQTT_PASSWORD=your-strong-password-here
MQTT_TOPIC=fluitrack/sensors/#   # wildcard to catch all sensor data

# FastAPI settings
SECRET_KEY=super-secret-key-change-me  # generate a real one later
